{
  "name": "@tangle-network/sandbox-ui",
  "version": "0.10.1",
  "description": "Unified UI component library for Tangle Sandbox — primitives, chat, dashboard, terminal, editor, and workspace components",
  "repository": {
    "type": "git",
    "url": "https://github.com/tangle-network/sandbox-ui"
  },
  "homepage": "https://github.com/tangle-network/sandbox-ui",
  "bugs": {
    "url": "https://github.com/tangle-network/sandbox-ui/issues"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./primitives": {
      "import": "./dist/primitives.js",
      "types": "./dist/primitives.d.ts"
    },
    "./chat": {
      "import": "./dist/chat.js",
      "types": "./dist/chat.d.ts"
    },
    "./run": {
      "import": "./dist/run.js",
      "types": "./dist/run.d.ts"
    },
    "./workspace": {
      "import": "./dist/workspace.js",
      "types": "./dist/workspace.d.ts"
    },
    "./openui": {
      "import": "./dist/openui.js",
      "types": "./dist/openui.d.ts"
    },
    "./files": {
      "import": "./dist/files.js",
      "types": "./dist/files.d.ts"
    },
    "./dashboard": {
      "import": "./dist/dashboard.js",
      "types": "./dist/dashboard.d.ts"
    },
    "./editor": {
      "import": "./dist/editor.js",
      "types": "./dist/editor.d.ts"
    },
    "./terminal": {
      "import": "./dist/terminal.js",
      "types": "./dist/terminal.d.ts"
    },
    "./markdown": {
      "import": "./dist/markdown.js",
      "types": "./dist/markdown.d.ts"
    },
    "./auth": {
      "import": "./dist/auth.js",
      "types": "./dist/auth.d.ts"
    },
    "./pages": {
      "import": "./dist/pages.js",
      "types": "./dist/pages.d.ts"
    },
    "./hooks": {
      "import": "./dist/hooks.js",
      "types": "./dist/hooks.d.ts"
    },
    "./sdk-hooks": {
      "import": "./dist/sdk-hooks.js",
      "types": "./dist/sdk-hooks.d.ts"
    },
    "./stores": {
      "import": "./dist/stores.js",
      "types": "./dist/stores.d.ts"
    },
    "./types": {
      "import": "./dist/types.js",
      "types": "./dist/types.d.ts"
    },
    "./utils": {
      "import": "./dist/utils.js",
      "types": "./dist/utils.d.ts"
    },
    "./styles": "./dist/styles.css",
    "./globals.css": "./dist/globals.css",
    "./tokens.css": "./dist/tokens.css",
    "./tailwind": "./tailwind.config.cjs"
  },
  "files": [
    "dist",
    "tailwind.config.cjs"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19"
  },
  "peerDependenciesMeta": {
    "@xterm/xterm": {
      "optional": true
    },
    "@xterm/addon-fit": {
      "optional": true
    },
    "@xterm/addon-web-links": {
      "optional": true
    },
    "@tanstack/react-query": {
      "optional": true
    },
    "nanostores": {
      "optional": true
    },
    "@nanostores/react": {
      "optional": true
    },
    "@hocuspocus/provider": {
      "optional": true
    },
    "@tiptap/core": {
      "optional": true
    },
    "@tiptap/react": {
      "optional": true
    },
    "@tiptap/starter-kit": {
      "optional": true
    },
    "@tiptap/extension-collaboration": {
      "optional": true
    },
    "@tiptap/extension-collaboration-caret": {
      "optional": true
    },
    "yjs": {
      "optional": true
    }
  },
  "dependencies": {
    "@nanostores/react": "^1.1.0",
    "@radix-ui/react-avatar": "^1.1.0",
    "@radix-ui/react-collapsible": "^1.1.0",
    "@radix-ui/react-dialog": "^1.1.0",
    "@radix-ui/react-dropdown-menu": "^2.1.0",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-progress": "^1.1.0",
    "@radix-ui/react-select": "^2.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-switch": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.0",
    "@radix-ui/react-toast": "^1.2.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.469.0",
    "marked": "^17.0.5",
    "nanostores": "^1.2.0",
    "react-markdown": "^10.1.0",
    "react-pdf": "^9.2.1",
    "react-syntax-highlighter": "^16.1.1",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.0.2",
    "turndown": "^7.2.2"
  },
  "pnpm": {
    "overrides": {
      "picomatch": ">=4.0.4"
    }
  },
  "devDependencies": {
    "@hocuspocus/provider": "^3.4.4",
    "@storybook/addon-essentials": "^8",
    "@storybook/addon-mcp": "^0.4.2",
    "@storybook/react": "^8.6.18",
    "@storybook/react-vite": "^8.6.18",
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-query": "^5.91.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@tiptap/core": "^3.20.4",
    "@tiptap/extension-collaboration": "^3.20.4",
    "@tiptap/extension-collaboration-caret": "^3.7.0",
    "@tiptap/react": "^3.20.4",
    "@tiptap/starter-kit": "^3.20.4",
    "@types/react": "^19.1.2",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/turndown": "^5.0.6",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "jsdom": "^29.0.2",
    "postcss": "^8.5.8",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "storybook": "^8.6.18",
    "tailwindcss": "^4.1.4",
    "tailwindcss-animate": "^1.0.7",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "vite": "^8.0.5",
    "vitest": "^4.1.3",
    "yjs": "^13.6.30"
  }
}
